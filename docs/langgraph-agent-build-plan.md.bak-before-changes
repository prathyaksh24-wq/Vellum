### `agent/graph/graph.py`
```python
"""
Main LangGraph graph definition.
Compile this once and call .stream() or .invoke() per message.

GRAPH FLOW:
  intake → access_control → classifier
    → [RED: end_blocked]
    → [YELLOW/GREEN: retriever → reranker → confidence_check]
        → [low_confidence: tool_router]
            → [tool: run_tool → store_response → learner → END]
            → [no_tool: answer_no_info → store_response → END]
        → [sufficient: llm_answer → store_response → learner → END]
"""
from langgraph.graph import StateGraph, END
from langgraph.checkpoint.sqlite import SqliteSaver
from agent.graph.state import AgentState
from agent.graph.nodes import (
    intake, access_control, classifier,
    retriever, reranker, confidence_check,
    tool_router, llm_answer,
    store_response, learner,
)
from agent.graph.edges import (
    route_after_classifier,
    route_after_confidence,
    route_after_tool_router,
)
from agent.config import settings

def build_graph():
    builder = StateGraph(AgentState)

    # ── Nodes ──────────────────────────────────────────────
    builder.add_node("intake",           intake.run)
    builder.add_node("access_control",   access_control.run)
    builder.add_node("classifier",       classifier.run)
    builder.add_node("retriever",        retriever.run)
    builder.add_node("reranker",         reranker.run)
    builder.add_node("confidence_check", confidence_check.run)
    builder.add_node("tool_router",      tool_router.run)
    builder.add_node("llm_answer",       llm_answer.run)
    builder.add_node("store_response",   store_response.run)
    builder.add_node("learner",          learner.run)

    # ── Edges ──────────────────────────────────────────────
    builder.set_entry_point("intake")

    builder.add_edge("intake",           "access_control")
    builder.add_edge("access_control",   "classifier")

    # After classifier: RED → END, else → retriever
    builder.add_conditional_edges(
        "classifier",
        route_after_classifier,
        {"blocked": END, "continue": "retriever"},
    )

    builder.add_edge("retriever",        "reranker")
    builder.add_edge("reranker",         "confidence_check")

    # After confidence: sufficient → llm_answer, low → tool_router
    builder.add_conditional_edges(
        "confidence_check",
        route_after_confidence,
        {"sufficient": "llm_answer", "insufficient": "tool_router"},
    )

    # After tool_router: use_tool → run inline, no_tool → llm_answer with no_info flag
    builder.add_conditional_edges(
        "tool_router",
        route_after_tool_router,
        {"use_tool": "llm_answer", "no_tool": "llm_answer"},
    )

    builder.add_edge("llm_answer",       "store_response")
    builder.add_edge("store_response",   "learner")
    builder.add_edge("learner",          END)

    # ── Checkpointer ───────────────────────────────────────
    checkpointer = SqliteSaver.from_conn_string("data/memory/checkpoints.db")

    return builder.compile(checkpointer=checkpointer)


# Singleton graph instance
graph = build_graph()
```

### `agent/graph/edges.py`
```python
"""Conditional edge routing logic"""
from agent.graph.state import AgentState

def route_after_classifier(state: AgentState) -> str:
    if state.get("blocked"):
        return "blocked"
    return "continue"

def route_after_confidence(state: AgentState) -> str:
    score = state.get("retrieval_confidence", 0.0)
    tool_needed = state.get("tool_needed", False)
    from agent.config import settings
    if score >= settings.MIN_RETRIEVAL_SCORE and not tool_needed:
        return "sufficient"
    return "insufficient"

def route_after_tool_router(state: AgentState) -> str:
    if state.get("tool_needed") and state.get("tool_name"):
        return "use_tool"
    return "no_tool"
