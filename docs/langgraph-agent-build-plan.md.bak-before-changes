"""
Node 4: RETRIEVER
- Embed the clean query
- Search Qdrant across all indexed collections
- Filter results by folder policy (only retrieve from indexed folders)
- Return raw chunks WITH folder metadata
"""
from agent.graph.state import AgentState
from agent.rag.embedder import Embedder
from agent.rag.store import VectorStore
from agent.obsidian.folder_policy import FolderPermission, get_policy
from agent.config import settings
import logging

logger = logging.getLogger(__name__)
embedder = Embedder()
vector_store = VectorStore()

async def run(state: AgentState) -> AgentState:
    clean_query = state.get("clean_query") or state["query"]

    # Embed the query locally (BGE-M3, no API call)
    query_embedding = embedder.embed(clean_query)

    # Search the main vault collection
    results = vector_store.search(
        collection="obsidian_vault",
        embedding=query_embedding,
        top_k=10,  # Get more than needed, reranker will trim
        score_threshold=0.45,  # Loose threshold here, confidence_check handles final gate
    )

    if not results:
        logger.info("[RETRIEVER] No results found in vault")
        return {
            **state,
            "retrieved_chunks": [],
            "retrieval_confidence": 0.0,
        }

    # Attach folder policy to each chunk
    enriched = []
    for r in results:
        folder = r["metadata"].get("folder", "")
        policy = get_policy(folder)
        enriched.append({
            **r,
            "can_send_to_llm": FolderPermission.SENT_TO_LLM in policy.permissions,
            "needs_scrubbing": policy.requires_scrubbing,
        })

    top_score = max(r["score"] for r in results)
    logger.info(f"[RETRIEVER] Found {len(results)} chunks, top score: {top_score:.3f}")

    return {
        **state,
        "retrieved_chunks": enriched,
        "retrieval_confidence": top_score,
    }
