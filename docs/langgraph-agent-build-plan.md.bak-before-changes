## PHASE 4 — GRAPH NODES (one file per node)

### `agent/graph/nodes/intake.py`
```python
"""
Node 1: INTAKE
- Receives raw query
- Writes query to Obsidian (Agent/Queries folder)
- Stores query embedding in Qdrant (for dedup + future retrieval)
- Checks for near-duplicate queries
"""
from langchain_core.messages import HumanMessage
from agent.graph.state import AgentState
from agent.obsidian.vault import ObsidianVault
from agent.rag.store import VectorStore
from agent.rag.embedder import Embedder
from agent.config import settings
from datetime import datetime
import logging

logger = logging.getLogger(__name__)
vault = ObsidianVault(settings.OBSIDIAN_VAULT_PATH)
vector_store = VectorStore()
embedder = Embedder()

DEDUP_THRESHOLD = 0.92  # Cosine similarity — above this = duplicate

async def run(state: AgentState) -> AgentState:
    query = state["query"]
    logger.info(f"[INTAKE] Query: {query[:80]}...")

    # Check for near-duplicate query
    query_embedding = embedder.embed(query)
    existing = vector_store.search(
        collection="agent_queries",
        embedding=query_embedding,
        top_k=1,
        score_threshold=DEDUP_THRESHOLD,
    )

    if not existing:
        # Write query to Obsidian as a note
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M")
        note_content = f"**Query logged at {timestamp}**\n\n{query}"
        vault.create_note(
            folder=f"{settings.AGENT_NOTES_FOLDER}/Queries",
            title=f"Query {datetime.now().strftime('%Y%m%d_%H%M%S')}",
            content=note_content,
        )

        # Store query embedding in Qdrant
        vector_store.upsert(
            collection="agent_queries",
            text=query,
            embedding=query_embedding,
            metadata={
                "timestamp": timestamp,
                "folder": f"{settings.AGENT_NOTES_FOLDER}/Queries",
                "type": "query",
            }
        )
        logger.info("[INTAKE] Query stored in Obsidian + Qdrant")
    else:
        logger.info("[INTAKE] Near-duplicate query found, skipping re-storage")

    return {
        **state,
        "query": query,
        "query_stored": True,
        "messages": state.get("messages", []) + [HumanMessage(content=query)],
    }
```

### `agent/graph/nodes/access_control.py`
```python
"""
Node 2: ACCESS CONTROL
- Checks which Obsidian folders are relevant to the query topic
- Tags state with accessible folders for downstream nodes
"""
from agent.graph.state import AgentState
from agent.obsidian.folder_policy import can_send_to_llm, can_use_tools, FOLDER_POLICIES
import logging

logger = logging.getLogger(__name__)

# Simple keyword-to-folder mapping
# Expand this dict as your vault grows
TOPIC_FOLDER_MAP = {
    "nba": "Sports/NBA",
    "basketball": "Sports/NBA",
    "formula one": "Sports/Formula One",
    "f1": "Sports/Formula One",
    "racing": "Sports/Formula One",
    "football": "Sports/football",
    "soccer": "Sports/football",
    "premier league": "Sports/football",
    "tennis": "Sports/Tennis",
    "wimbledon": "Sports/Tennis",
    "sports": "Sports",
    "book": "Books",
    "reading": "Books",
    "youtube": "youtube",
    "feedback": "feedback",
}

async def run(state: AgentState) -> AgentState:
    query_lower = state["query"].lower()

    # Detect which folders are relevant
    relevant_folders = set()
    for keyword, folder in TOPIC_FOLDER_MAP.items():
        if keyword in query_lower:
            relevant_folders.add(folder)

    # If no specific folder detected, search all indexed folders
    if not relevant_folders:
        relevant_folders = set(FOLDER_POLICIES.keys())

    # Split into allowed vs private
    sendable_folders = {f for f in relevant_folders if can_send_to_llm(f)}
    tool_folders = {f for f in relevant_folders if can_use_tools(f)}

    logger.info(f"[ACCESS] Relevant folders: {relevant_folders}")
    logger.info(f"[ACCESS] Can send to LLM: {sendable_folders}")

    return {
        **state,
        "relevant_folders": list(relevant_folders),
        "sendable_folders": list(sendable_folders),
        "tool_accessible_folders": list(tool_folders),
    }
