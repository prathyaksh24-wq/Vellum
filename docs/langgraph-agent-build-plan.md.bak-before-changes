scrubber = PrivacyScrubber()

# Keywords that trigger Apify Amazon scraper
AMAZON_KEYWORDS = ["buy", "price", "product", "amazon", "review", "cost", "purchase", "deal"]

# Keywords that trigger filesystem
FILE_KEYWORDS = ["file", "read", "open", "document", "pdf", "show me"]

# High-importance queries where web search is justified
HIGH_IMPORTANCE_PATTERNS = [
    r"latest|current|today|recent|news|2025|2026",
    r"price of|how much|cost of",
    r"score|result|standings|winner",
]

def is_high_importance(query: str) -> bool:
    for pattern in HIGH_IMPORTANCE_PATTERNS:
        if re.search(pattern, query.lower()):
            return True
    return False

async def run(state: AgentState) -> AgentState:
    query = state.get("clean_query") or state["query"]
    query_lower = query.lower()

    # Check: Filesystem tool
    if any(kw in query_lower for kw in FILE_KEYWORDS):
        logger.info("[TOOL ROUTER] → Filesystem MCP")
        return {**state, "tool_needed": True, "tool_name": "filesystem", "tool_params": {"query": query}}

    # Check: Amazon scraper (Apify) — private
    tool_folders = state.get("tool_accessible_folders", [])
    if any(kw in query_lower for kw in AMAZON_KEYWORDS) and is_high_importance(query):
        logger.info("[TOOL ROUTER] → Apify Amazon scraper (private)")
        return {**state, "tool_needed": True, "tool_name": "apify_amazon", "tool_params": {"query": query}}

    # No tool — will answer with no_info
    logger.info("[TOOL ROUTER] No suitable tool found")
    return {**state, "tool_needed": False, "tool_name": "", "tool_params": {}}
