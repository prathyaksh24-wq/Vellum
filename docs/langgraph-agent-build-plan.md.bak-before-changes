"""
Node 8: LLM ANSWER
- Runs tool call if tool_needed (Filesystem or Apify)
- Builds final prompt from context + tool results
- Calls OpenRouter with ZDR enforced
- ONLY sends sanitized, allowed content
"""
from agent.graph.state import AgentState
from agent.llm.openrouter import openrouter_chat
from agent.mcp.filesystem_tools import run_tool as run_filesystem
from agent.mcp.apify_tools import run_tool as run_apify
from agent.privacy.scrubber import PrivacyScrubber
from langchain_core.messages import AIMessage
import logging

logger = logging.getLogger(__name__)
scrubber = PrivacyScrubber()

SYSTEM_PROMPT = """You are a personal knowledge assistant. You ONLY answer using the provided context from the user's notes and tools.
Rules:
- If the context contains the answer, provide it clearly and concisely.
- If the context does NOT contain a clear answer, say: "I don't have enough information about this in your vault."
- Never make up facts not present in the context.
- Be conversational and helpful.
- Reference which source/folder the information came from when relevant."""

async def run(state: AgentState) -> AgentState:
    query = state.get("clean_query") or state["query"]
    context = state.get("context_string", "")
    tool_result_clean = ""

    # Execute tool if needed
    if state.get("tool_needed") and state.get("tool_name"):
        tool_name = state["tool_name"]
        tool_params = state.get("tool_params", {})

        logger.info(f"[LLM ANSWER] Running tool: {tool_name}")

        if tool_name == "filesystem":
            raw_result = await run_filesystem(tool_params)
        elif tool_name == "apify_amazon":
            raw_result = await run_apify(tool_params)
            # Apify is private — scrub before LLM
            raw_result, _ = scrubber.scrub(str(raw_result))
        else:
            raw_result = "Tool not found."

        tool_result_clean = str(raw_result)[:2000]

        return {
            **state,
            "tool_result_clean": tool_result_clean,
            "answer": tool_result_clean,
            "answer_source": f"tool:{tool_name}",
            "messages": state.get("messages", []) + [AIMessage(content=tool_result_clean)],
        }

    # No sufficient context → no_info response
    if not context:
        answer = "I don't have enough information about this in your vault. Add more notes on this topic for better answers."
        return {
            **state,
            "answer": answer,
            "answer_source": "no_info",
            "messages": state.get("messages", []) + [AIMessage(content=answer)],
        }

    # Build prompt — only sanitized context goes to OpenRouter
    prompt = f"""Context from your knowledge vault:
{context}

Question: {query}"""

    answer = await openrouter_chat(
        system=SYSTEM_PROMPT,
        user=prompt,
    )

    logger.info(f"[LLM ANSWER] Answer generated ({len(answer)} chars)")

    return {
        **state,
        "answer": answer,
        "answer_source": "vault",
        "messages": state.get("messages", []) + [AIMessage(content=answer)],
    }
