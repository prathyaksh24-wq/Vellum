### `agent/graph/nodes/reranker.py`
```python
"""
Node 5: RERANKER
- Cross-encoder reranks retrieved chunks by true relevance to query
- Runs locally (no API) — ms-marco-MiniLM-L-6-v2
- Trims to MAX_CONTEXT_CHUNKS
- Applies PII scrubbing to chunks that need it
- Filters out chunks from private folders (not allowed to go to LLM)
"""
from sentence_transformers import CrossEncoder
from agent.graph.state import AgentState
from agent.privacy.scrubber import PrivacyScrubber
from agent.config import settings
import logging

logger = logging.getLogger(__name__)
scrubber = PrivacyScrubber()

# Loads once, runs offline (~80MB)
cross_encoder = CrossEncoder("cross-encoder/ms-marco-MiniLM-L-6-v2")

async def run(state: AgentState) -> AgentState:
    chunks = state.get("retrieved_chunks", [])
    query = state.get("clean_query") or state["query"]

    if not chunks:
        return {**state, "reranked_chunks": [], "allowed_chunks": [], "context_string": ""}

    # Cross-encoder scoring
    pairs = [(query, chunk["text"]) for chunk in chunks]
    scores = cross_encoder.predict(pairs)

    scored = sorted(
        zip(scores, chunks),
        key=lambda x: x[0],
        reverse=True,
    )

    # Take top N
    top_chunks = [chunk for _, chunk in scored[:settings.MAX_CONTEXT_CHUNKS]]

    # Separate: allowed vs private
    allowed = []
    for chunk in top_chunks:
        if not chunk.get("can_send_to_llm"):
            # Private folder — skip for LLM context
            logger.info(f"[RERANKER] Skipping private chunk from {chunk['metadata'].get('folder')}")
            continue

        # Scrub if needed
        if chunk.get("needs_scrubbing"):
            clean_text, _ = scrubber.scrub(chunk["text"])
            chunk = {**chunk, "text": clean_text}

        allowed.append(chunk)

    # Build context string
    context_parts = []
    for i, chunk in enumerate(allowed, 1):
        folder = chunk["metadata"].get("folder", "unknown")
        context_parts.append(f"[Source {i} — {folder}]\n{chunk['text']}")

    context_string = "\n\n---\n\n".join(context_parts)

    # Truncate to token limit
    max_chars = settings.MAX_CONTEXT_TOKENS * 4
    if len(context_string) > max_chars:
        context_string = context_string[:max_chars] + "\n[TRUNCATED]"

    logger.info(f"[RERANKER] {len(allowed)} chunks allowed for LLM context")

    return {
        **state,
        "reranked_chunks": top_chunks,
        "allowed_chunks": allowed,
        "context_string": context_string,
    }
```

