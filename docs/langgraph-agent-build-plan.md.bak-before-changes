"""
Node 7: TOOL ROUTER
- Decides whether to call Filesystem MCP or Apify MCP
- Applies web search privacy gate (importance check)
- Apify (Amazon scraper) is always private → result stored locally, scrubbed before LLM
"""
from agent.graph.state import AgentState
from agent.mcp.filesystem_tools import read_file, list_files
from agent.mcp.apify_tools import amazon_search
from agent.privacy.scrubber import PrivacyScrubber
import logging
import re

