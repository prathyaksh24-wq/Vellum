$graphite: #0c0c0e;
$charcoal: #131316;
$slate: #1a1a1c;
$warm-gray: #232326;
$parchment: #ece6db;
$vellum-paper: #f6f3ee;
$muted: #aaa49b;
$whisper: #716d68;
$ember: #d97746;
$soft-ember: #f1b27a;
$line: #24211f;

Screen {
    background: $graphite;
    color: $parchment;
}

VellumHeader {
    height: 2;
    color: $parchment;
    background: $graphite;
}

#topline {
    height: 1;
    padding: 0 2;
}

#rule,
#input-rule-top,
#input-rule-bottom {
    height: 1;
    color: $line;
}

#root {
    width: 100%;
    height: 100%;
    background: $graphite;
}

#body {
    height: 1fr;
}

#stage {
    width: 1fr;
    height: 100%;
}

MessageList {
    height: 1fr;
    padding: 2 10;
    scrollbar-color: $whisper;
    scrollbar-color-hover: $muted;
    scrollbar-background: $graphite;
    background: $graphite;
}

.landing {
    content-align: center middle;
    text-align: center;
    height: 100%;
    color: $muted;
}

.landing-title {
    color: $parchment;
    text-style: italic;
}

.message {
    margin-bottom: 2;
    width: 72;
}

.message-user {
    color: $muted;
}

.message-vellum {
    color: $parchment;
}

.meta {
    color: $whisper;
}

.stream-rule {
    color: $ember;
}

#input-wrap {
    height: auto;
    background: $graphite;
}

#slash-palette {
    display: none;
    margin: 0 2 1 2;
    padding: 1 2;
    border: solid $line;
    background: $charcoal;
    color: $muted;
    height: auto;
}

VellumInput {
    height: 1;
    border: none;
    padding: 0 2;
    background: $graphite;
    color: $parchment;
}

VellumInput:focus {
    background: $graphite;
}

#footer-line {
    height: 1;
    padding: 0 2;
    color: $whisper;
    background: $graphite;
}

ThreadsSidebar {
    width: 31;
    height: 100%;
    padding: 1 2;
    background: $charcoal;
    color: $muted;
    border-right: solid $line;
    display: none;
}

ThreadsSidebar.open {
    display: block;
}

LedgerSidebar {
    width: 38;
    height: 100%;
    padding: 1 2;
    background: $charcoal;
    color: $muted;
    border-left: solid $line;
    display: none;
}

LedgerSidebar.open {
    display: block;
}

.side-title {
    color: $parchment;
    text-style: italic;
    margin-bottom: 1;
}

.side-section {
    color: $whisper;
    margin-top: 1;
}

.active-thread {
    color: $ember;
}

.help {
    width: 62;
    height: auto;
    border: solid $line;
    background: $slate;
    color: $parchment;
    padding: 1 2;
}

LedgerScreen {
    background: $graphite;
    color: $parchment;
}

#ledger-root {
    width: 100%;
    height: 100%;
    background: $graphite;
}

#ledger-header,
#ledger-rule,
#ledger-footer {
    height: 1;
    padding: 0 2;
}

#ledger-header {
    color: $parchment;
}

#ledger-rule {
    color: $line;
}

#ledger-footer {
    color: $whisper;
}

#ledger-grid {
    height: 1fr;
    grid-size: 2 2;
    grid-gutter: 1 2;
    padding: 2 4;
}

#period-panel,
#models-panel,
#threads-panel,
#hours-panel {
    padding: 1 2;
    border: solid $line;
    background: $graphite;
    color: $muted;
}
